<!-- _MyPostsTab.cshtml -->
<div class="stats-grid stats-grid--5">
    <div class="stat-card">
        <div class="stat-label">Total Posts</div>
        <div class="stat-value stat-value--default">2</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Open</div>
        <div class="stat-value stat-value--green">1</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Closed</div>
        <div class="stat-value stat-value--red">1</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Expired</div>
        <div class="stat-value stat-value--default">0</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Applications</div>
        <div class="stat-value stat-value--blue">7</div>
    </div>
</div>

<div class="posts-grid">
    <!-- Post Card 1 - Open -->
    <div class="post-card">
        <div class="post-card__header">
            <div class="post-card__tags">
                <span class="badge badge--category">Sports</span>
                <span class="badge badge--open">Open</span>
            </div>
            <span class="post-card__time">3 days ago</span>
        </div>

        <h3 class="post-card__title">Looking for Football Teammates - Sunday Match</h3>
        <p class="post-card__desc">We need 3 more players for a friendly football match this Sunday at Central Park. All skill levels welcome!</p>

        <div class="post-card__meta">
            <div class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>Central Park, Field 3</span>
            </div>
            <div class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>2 / 3 members</span>
                <span class="spots-left">(<span class="spots-highlight">1 spots left</span>)</span>
            </div>
            <div class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Expires: 2/15/2026</span>
            </div>
        </div>

        <div class="post-card__footer">
            <span class="post-author">by Alex Johnson</span>
            <span class="post-apps">3 applications</span>
        </div>
    </div>

    <!-- Post Card 2 - Closed -->
    <div class="post-card">
        <div class="post-card__header">
            <div class="post-card__tags">
                <span class="badge badge--category badge--dining">Dining</span>
                <span class="badge badge--closed">Closed</span>
            </div>
            <span class="post-card__time">7 days ago</span>
        </div>

        <h3 class="post-card__title">Weekend Brunch Crew</h3>
        <p class="post-card__desc">Let's make weekend brunch a regular thing! Looking for 5 people interested in trying different brunch spots</p>

        <div class="post-card__meta">
            <div class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>Various locations</span>
            </div>
            <div class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>5 / 5 members</span>
            </div>
            <div class="meta-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Expires: 2/13/2026</span>
            </div>
        </div>

        <div class="post-card__footer">
            <span class="post-author">by Alex Johnson</span>
            <span class="post-apps">4 applications</span>
        </div>
    </div>
</div>
