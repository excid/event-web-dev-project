@model event_web_dev_project.Models.MyInvitationsTabModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery AntiForgery

<!-- _InvitationsTab.cshtml -->
<input type="hidden" id="invitation-antiforgery-token" value="@AntiForgery.GetAndStoreTokens(Context).RequestToken" />

<!-- ── Confirmation Modal ── -->
<div id="confirm-modal" class="confirm-modal-overlay">
    <div class="confirm-modal">
        <button class="confirm-modal__close" onclick="closeConfirmModal()" aria-label="Close">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div id="confirm-modal-icon" class="confirm-modal__icon"></div>
        <h3 id="confirm-modal-title" class="confirm-modal__title"></h3>
        <p id="confirm-modal-body" class="confirm-modal__body"></p>
        <div class="confirm-modal__actions">
            <button class="btn-modal-cancel" onclick="closeConfirmModal()">Cancel</button>
            <button id="confirm-modal-confirm" onclick="confirmModalAction()"></button>
        </div>
    </div>
</div>

<div class="subtab-nav">
    <button class="subtab-btn active" data-subtab="received">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Received (@Model.ReceivedTotalInvitations)
    </button>
    <button class="subtab-btn" data-subtab="sent">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Sent (@Model.SentTotalInvitations)
    </button>
</div>

<!-- Received Subtab -->
<div class="subtab-panel active" id="subtab-received">
    <div class="stats-grid stats-grid--4">
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Total Received</div>
            <div class="stat-value stat-value--default">@Model.ReceivedTotalInvitations</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Pending</div>
            <div class="stat-value stat-value--amber">@Model.ReceivedPendingInvitations</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Accepted</div>
            <div class="stat-value stat-value--green">@Model.ReceivedAcceptedInvitations</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Rejected</div>
            <div class="stat-value stat-value--red">@Model.ReceivedRejectedInvitations</div>
        </div>
    </div>
    <div class="invitations-list">
        @foreach (var receivedInvitation in Model.ReceivedInvitations)
        {
        <div class="invitation-card" data-invitation-id="@receivedInvitation.InvitationId">
            <div class="invitation-card__top">
                <div>
                    <h3 class="invitation-card__title">@receivedInvitation.Title</h3>
                    <p class="invitation-card__meta">From <a href="/Profile/Index?userId=@receivedInvitation.SenderUserId" class="user-link">@receivedInvitation.Sender</a> • @receivedInvitation.ReceivedDate.ToString("M/d/yyyy")</p>
                    <p class="invitation-card__event">Event: @receivedInvitation.EventDate.ToString("M/d/yyyy")</p>
                </div>
                <div class="status-badge status-badge--@(receivedInvitation.Status?.ToLower())">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span>@receivedInvitation.Status</span>
                </div>
            </div>
            <div class="invitation-card__msg">@receivedInvitation.Message</div>
            @if (receivedInvitation.Status == "Pending")
            {
            <div class="invitation-card__actions">
                <button class="btn-accept" onclick="showConfirmModal(this, 'accept')">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    Accept Invitation
                </button>
                <button class="btn-decline" onclick="showConfirmModal(this, 'decline')">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    Decline
                </button>
            </div>
            }
        </div>
        }
    </div>
</div>

<!-- Sent Subtab -->
<div class="subtab-panel" id="subtab-sent">
    <div class="stats-grid stats-grid--4">
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Total Sent</div>
            <div class="stat-value stat-value--default">@Model.SentTotalInvitations</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Pending</div>
            <div class="stat-value stat-value--amber">@Model.SentPendingInvitations</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Accepted</div>
            <div class="stat-value stat-value--green">@Model.SentAcceptedInvitations</div>
        </div>
        <div class="stat-card stat-card--sm">
            <div class="stat-label">Rejected</div>
            <div class="stat-value stat-value--red">@Model.SentRejectedInvitations</div>
        </div>
    </div>

    <div class="invitations-list">
        @foreach (var sentInvitation in Model.SentInvitations) {
        <div class="invitation-card">
            <div class="invitation-card__top">
                <div>
                    <h3 class="invitation-card__title">@sentInvitation.Title</h3>
                    <p class="invitation-card__meta">To <a href="#" class="user-link">@sentInvitation.Receiver</a> • @sentInvitation.SentDate</p>
                    <p class="invitation-card__event">Event: @sentInvitation.EventDate</p>
                </div>
                <div class="status-badge status-badge--@(sentInvitation.Status?.ToLower())">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span>@sentInvitation.Status</span>
                </div>
            </div>
            <div class="invitation-card__msg">@sentInvitation.Message</div>
            <div class="invitation-card__notice status-badge--@(sentInvitation.Status?.ToLower())">
                @sentInvitation.StatusMessage
            </div>
        </div>
        }
    </div>
</div>
