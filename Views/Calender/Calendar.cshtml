@model event_web_dev_project.Models.CalendarViewModel
@{
    ViewData["Title"] = "Activity Calendar";
    var monthName = new DateTime(Model.CurrentYear, Model.CurrentMonth, 1).ToString("MMMM yyyy");
}

@section Head {
    <link rel="stylesheet" href="~/css/calendar.css" />
}

<div class="container mt-4">
    <h2 class="fw-bold">Activity Calendar</h2>
    <p class="text-muted">View activities by their expiration dates</p>

    <div class="row mt-4">
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="mb-0 fw-bold">@monthName</h4>
                        <div>
                            <a href="@Url.Action("Calendar", new { year = Model.CurrentMonth == 1 ? Model.CurrentYear - 1 : Model.CurrentYear, month = Model.CurrentMonth == 1 ? 12 : Model.CurrentMonth - 1 })" class="btn btn-outline-secondary btn-sm px-3">&lt;</a>
                            <a href="@Url.Action("Calendar", new { year = Model.CurrentMonth == 12 ? Model.CurrentYear + 1 : Model.CurrentYear, month = Model.CurrentMonth == 12 ? 1 : Model.CurrentMonth + 1 })" class="btn btn-outline-secondary btn-sm px-3">&gt;</a>
                        </div>
                    </div>

                    <div class="cal-grid cal-header">
                        <div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div>
                    </div>

                    <div class="cal-grid">
                        @foreach (var day in Model.Days)
                        {
                            var isSelected = day.Date.Date == Model.SelectedDate.Date ? "selected-day" : "";
                            var isCurrent = day.IsCurrentMonth ? "" : "not-current-month";

                            <div class="cal-day @isCurrent @isSelected" onclick="selectDate('@day.Date.ToString("yyyy-MM-dd")', this)">
                                <div class="date-number">@day.Date.Day</div>
                                
                                @foreach (var ev in day.Events.Take(2))
                                {
                                    <div class="event-pill @ev.CssColorClass" title="@ev.Title">
                                        @ev.Title
                                    </div>
                                }
                                @if (day.Events.Count > 2)
                                {
                                    <div class="text-muted text-center mt-1" style="font-size:0.7rem; font-weight:600;">
                                        +@(day.Events.Count - 2) more
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="d-flex align-items-center flex-wrap gap-2 mt-3" style="font-size: 0.85rem;">
                <strong class="me-2">Category Legend</strong>
                <span class="badge rounded-pill cat-sports px-3 py-2">Sports</span>
                <span class="badge rounded-pill cat-dining px-3 py-2">Dining</span>
                <span class="badge rounded-pill cat-social px-3 py-2">Social</span>
                <span class="badge rounded-pill cat-shopping px-3 py-2">Shopping</span>
                <span class="badge rounded-pill cat-study px-3 py-2">Study</span>
                <span class="badge rounded-pill cat-others px-3 py-2">Others</span>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0" style="min-height: 500px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4" id="detailDateLabel">@Model.SelectedDate.ToString("MMMM dd, yyyy")</h5>
                    
                    <h6 class="text-muted fw-bold mb-3">Activities</h6>
                    <div id="activitiesContainer">
                        </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // โหลดข้อมูลกิจกรรมทั้งหมดในเดือนนี้มาไว้ใน JavaScript
        const allEvents = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AllEventsThisMonth));

        function selectDate(dateString, element) {
            // อัปเดตกรอบสีฟ้า
            if (element) {
                document.querySelectorAll('.cal-day').forEach(el => el.classList.remove('selected-day'));
                element.classList.add('selected-day');
            }

            // แปลงวันที่เพื่อแสดงผลด้านขวา
            const [year, month, day] = dateString.split('-');
            const dateObj = new Date(year, month - 1, day);
            document.getElementById('detailDateLabel').innerText = dateObj.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

            // ค้นหากิจกรรมในวันที่เลือก
            const eventsForDate = allEvents.filter(e => e.EventDate.startsWith(dateString));
            const container = document.getElementById('activitiesContainer');
            container.innerHTML = '';

            if (eventsForDate.length === 0) {
                container.innerHTML = '<div class="text-center text-muted mt-5"><p>No activities scheduled.</p></div>';
                return;
            }

            // วาดการ์ดกิจกรรมฝั่งขวา
            eventsForDate.forEach(ev => {
                let badgeClass = ev.CssColorClass;
                let statusHtml = ev.Status ? `<span class="badge bg-light text-dark float-end border">${ev.Status}</span>` : '';
                
                let sourceBadge = ev.SourceType === 'Post' 
                    ? `<span class="badge bg-light text-primary border border-primary float-end me-1">My Event</span>` 
                    : `<span class="badge bg-light text-success border border-success float-end me-1">Joined</span>`;

                container.innerHTML += `
                    <div class="activity-card">
                        ${statusHtml}
                        ${sourceBadge}
                        <span class="activity-badge text-white ${badgeClass}">${ev.Category}</span>
                        <h6 class="fw-bold mt-2 mb-1">${ev.Title}</h6>
                        <p class="text-muted small mb-0">by ${ev.Author}</p>
                    </div>
                `;
            });
        }

        // ให้แสดงข้อมูลของวันปัจจุบัน (หรือวันที่ถูกเลือก) ตอนโหลดหน้าเว็บเสร็จ
        window.addEventListener('DOMContentLoaded', (event) => {
            selectDate('@Model.SelectedDate.ToString("yyyy-MM-dd")', null);
        });
    </script>
}