@model event_web_dev_project.Models.ActivityPost
@* Views/ActivityPost/Index.cshtml *@

<link rel="stylesheet" href="~/css/activity_post.css" />
@Html.AntiForgeryToken()

@if (Model == null)
{
    <div style="text-align:center; padding:60px; color:#6b7280;">
        <p>No posts available yet.</p>
    </div>
}
else
{
    <div style="padding:16px 24px 0;">
        <a href="@Url.Action("Index", "Home")" class="back-link">
            <span data-icon="back"></span>
            Back
        </a>
    </div>

    <div class="event-detail-layout">

        <!-- ===== Left: Event Card ===== -->
        <div class="event-card">
            <div class="event-card-header">
                <span class="badge badge-sports">@Model.Category</span>
                <span class="badge @(Model.Status == "Open" ? "badge-open" : "badge-closed")">
                    @Model.Status
                </span>
            </div>

            <h1 class="event-title">@Model.Title</h1>

            <p class="event-posted-by">
                Posted by <a href="@(ViewBag.OwnerUsername != null ? Url.Action("Index", "Profile", new { username = (string)ViewBag.OwnerUsername }) : Url.Action("Index", "Profile"))">@Model.PostedBy</a>
                &bull; @Model.PostedAt.ToString("MMM d, yyyy")
            </p>

            <p class="event-section-label">Description</p>
            <p class="event-description">@Model.Description</p>

            <div class="event-meta-grid">
                <div class="event-meta-item">
                    <span class="meta-icon" data-icon="location"></span>
                    <div>
                        <div class="meta-label">Location</div>
                        <div class="meta-value">@Model.Location</div>
                    </div>
                </div>
                <div class="event-meta-item">
                    <span class="meta-icon" data-icon="members"></span>
                    <div>
                        <div class="meta-label">Members</div>
                        <div class="meta-value" id="member-count">
                            @Model.CurrentMembers / @Model.MaxMembers joined
                            @if (Model.SpotsLeft > 0)
                            {
                                <span class="meta-spots">(@Model.SpotsLeft spots left)</span>
                            }
                            else
                            {
                                <span class="meta-spots" style="color:#ef4444;">(Full)</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="event-meta-item">
                    <span class="meta-icon" data-icon="calendar"></span>
                    <div>
                        <div class="meta-label">Expires</div>
                        <div class="meta-value">@Model.ExpiresAt.ToString("MMM d, yyyy h:mm tt")</div>
                    </div>
                </div>
                <div class="event-meta-item">
                    <span class="meta-icon" data-icon="calendar"></span>
                    <div>
                        <div class="meta-label">Activity Date</div>
                        <div class="meta-value">@Model.ActivityDate.ToString("MMM d, yyyy h:mm tt")</div>
                    </div>
                </div>
                <div class="event-meta-item">
                    <span class="meta-icon" data-icon="clock"></span>
                    <div>
                        <div class="meta-label">Application Mode</div>
                        <div class="meta-value">@Model.ApplicationMode</div>
                    </div>
                </div>
            </div>

           
            <button class="btn-close-post"
                    data-action="close-post"
                    data-post-id="@Model.Id">
                <span data-icon="close"></span>
                @if (Model.Status == "Open")
                {
                    @:Close Post
                }
                else          
                {
                    @:Delete Post
                }
            </button>

            @* ===== Review Section — only visible when post is Closed ===== *@
            @if (Model.Status == "Closed")
            {
                <div class="review-section">
                    <h3 class="review-section-title">⭐ Leave Reviews</h3>
                    <p class="review-section-subtitle">Rate Participants</p>

                    <div class="review-list">
                        @* Loop real accepted applications *@
                        @foreach (var app in Model.Applications.Where(a => a.Status == "Accepted"))
                        {
                            <div class="review-participant-row">
                                <div>
                                    <div class="review-participant-name">@app.ApplicantName</div>
                                    <div class="review-participant-label">Participant</div>
                                </div>
                                <button class="btn-rate"
                                        data-reviewee-name="@app.ApplicantName"
                                        data-reviewee-id="@app.ApplicantId"
                                        data-post-id="@Model.Id">
                                    ⭐ Rate
                                </button>
                            </div>
                        }
                    </div>

                    <p class="review-note">
                        ℹ️ Reviews help build trust in the community. You can choose to submit your review publicly or anonymously.
                    </p>
                </div>
            }
        </div>

        <!-- ===== Right: Applications Panel ===== -->
        <div class="applications-panel">
            <h2 class="applications-title">Applications (@Model.Applications.Count)</h2>

            @if (!Model.Applications.Any())
            {
                <p style="color:#9ca3af; font-size:0.88rem;">No applications yet.</p>
            }
            else
            {
                <div class="application-list">
                    @foreach (var app in Model.Applications)
                    {
                        <div class="application-card">
                            <div class="application-card-header">
                                <span class="applicant-name">@app.ApplicantName</span>
                                <span class="badge @GetStatusBadgeClass(app.Status)">@app.Status</span>
                            </div>
                            <div class="application-time">
                                @app.AppliedAt.ToString("MMM d, h:mm tt")
                            </div>
                            <p class="application-message">@app.Message</p>

                            @if (app.Status == "Pending" && Model.Status == "Open")
                            {
                                <div class="application-actions">
                                    <button class="btn-accept"
                                            data-action="accept"
                                            data-application-id="@app.Id"
                                            data-post-id="@Model.Id">
                                        <span data-icon="check"></span>
                                        Accept
                                    </button>
                                    <button class="btn-reject"
                                            data-action="reject"
                                            data-application-id="@app.Id"
                                            data-post-id="@Model.Id">
                                        <span data-icon="x"></span>
                                        Reject
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

    </div>

    @* ===== Review Modal ===== *@
}

<script src="~/js/icons.js"></script>
<script src="~/js/events.js"></script>

@if (Model.Status == "Closed")
{
    <script>
    /* ── Participant Review Modal ─────────────────────────────────────────── */
    (function () {
        var activityDateUtc = new Date('@Model.ActivityDate.ToString("o")');
        var activityPassed  = new Date() >= activityDateUtc;

        var selectedStars  = 0;
        var currentPostId  = '';
        var currentRevieweeId   = '';
        var currentRevieweeName = '';
        var starLabels = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];

        /* ── Create modal DOM ─────────────────────────────────────────── */
        var modal = document.createElement('div');
        modal.id = 'review-modal';
        modal.className = 'modal-overlay';
        modal.style.display = 'none';
        modal.innerHTML =
            '<div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="review-modal-title">' +
                '<div class="modal-header">' +
                    '<h3 class="modal-title" id="review-modal-title">Rate <span id="modal-reviewee-name"></span></h3>' +
                    '<button class="modal-close-btn" id="modal-close-btn" aria-label="Close">&times;</button>' +
                '</div>' +
                '<div class="star-picker" id="star-picker">' +
                    '<span class="star-pick" data-value="1">★</span>' +
                    '<span class="star-pick" data-value="2">★</span>' +
                    '<span class="star-pick" data-value="3">★</span>' +
                    '<span class="star-pick" data-value="4">★</span>' +
                    '<span class="star-pick" data-value="5">★</span>' +
                '</div>' +
                '<p id="star-label" class="star-label-text">Select a rating</p>' +
                '<textarea id="review-comment" class="review-textarea" placeholder="Leave a comment (optional)"></textarea>' +
                '<label style="display:flex;align-items:center;gap:8px;margin-bottom:16px;font-size:0.88rem;color:#374151;">' +
                    '<input type="checkbox" id="review-anonymous">' +
                    'Submit anonymously' +
                '</label>' +
                '<div class="modal-actions">' +
                    '<button class="btn-modal-cancel" id="modal-cancel-btn">Cancel</button>' +
                    '<button class="btn-modal-submit" id="modal-submit-btn">Submit Review</button>' +
                '</div>' +
                '<p id="review-feedback" style="text-align:center;font-size:0.85rem;margin-top:10px;color:#dc2626;"></p>' +
            '</div>';
        document.body.appendChild(modal);

        /* ── Star helpers ─────────────────────────────────────────────── */
        function highlightStars(count) {
            modal.querySelectorAll('.star-pick').forEach(function (s, i) {
                s.style.color = i < count ? '#f59e0b' : '#d1d5db';
                s.classList.toggle('active', i < count);
            });
        }

        function shakeStarPicker() {
            var picker = document.getElementById('star-picker');
            picker.style.animation = 'none';
            picker.offsetHeight;
            picker.style.animation = 'shake 0.3s ease';
        }

        /* ── Open / close ─────────────────────────────────────────────── */
        function openModal(btn) {
            currentPostId       = btn.dataset.postId;
            currentRevieweeId   = btn.dataset.revieweeId || '';
            currentRevieweeName = btn.dataset.revieweeName || '';
            document.getElementById('modal-reviewee-name').textContent = currentRevieweeName;
            selectedStars = 0;
            document.getElementById('star-label').textContent = 'Select a rating';
            document.getElementById('review-comment').value = '';
            document.getElementById('review-anonymous').checked = false;
            document.getElementById('review-feedback').textContent = '';
            document.getElementById('modal-submit-btn').textContent = 'Submit Review';
            document.getElementById('modal-submit-btn').disabled = false;
            highlightStars(0);
            modal.style.display = 'flex';
        }

        function closeModal() {
            modal.style.display = 'none';
        }

        /* ── Star events (direct listeners) ──────────────────────────── */
        modal.querySelectorAll('.star-pick').forEach(function (star) {
            star.addEventListener('mouseover', function () {
                highlightStars(parseInt(star.dataset.value));
            });
            star.addEventListener('mouseout', function () {
                highlightStars(selectedStars);
            });
            star.addEventListener('click', function () {
                selectedStars = parseInt(star.dataset.value);
                highlightStars(selectedStars);
                document.getElementById('star-label').textContent = starLabels[selectedStars];
            });
        });

        /* ── Submit ───────────────────────────────────────────────────── */
        document.getElementById('modal-submit-btn').addEventListener('click', async function () {
            if (selectedStars === 0) { shakeStarPicker(); return; }

            var comment   = document.getElementById('review-comment').value.trim();
            var anonymous = document.getElementById('review-anonymous').checked;
            var token     = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            var submitBtn = document.getElementById('modal-submit-btn');
            var feedback  = document.getElementById('review-feedback');

            submitBtn.disabled = true;
            submitBtn.textContent = 'Submitting…';

            try {
                var body = new URLSearchParams({
                    postId:       currentPostId,
                    revieweeId:   currentRevieweeId,
                    revieweeName: currentRevieweeName,
                    rating:       selectedStars,
                    comment:      comment,
                    isAnonymous:  anonymous,
                    __RequestVerificationToken: token
                });

                var resp = await fetch('/Review/Submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body
                });
                var result = await resp.json();

                if (result.success) {
                    closeModal();
                    var rateBtn = document.querySelector('.btn-rate[data-reviewee-name="' + currentRevieweeName + '"]');
                    if (rateBtn) {
                        rateBtn.outerHTML = '<span class="btn-rate-done">' +
                            '★'.repeat(selectedStars) + '☆'.repeat(5 - selectedStars) +
                        '</span>';
                    }
                    EventBoard.toast('Review submitted for ' + currentRevieweeName + '!');
                } else {
                    feedback.textContent = result.error ?? 'Something went wrong.';
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Submit Review';
                }
            } catch (e) {
                feedback.textContent = 'Network error, please try again.';
                submitBtn.disabled = false;
                submitBtn.textContent = 'Submit Review';
            }
        });

        /* ── Close listeners ──────────────────────────────────────────── */
        document.getElementById('modal-close-btn').addEventListener('click', closeModal);
        document.getElementById('modal-cancel-btn').addEventListener('click', closeModal);
        modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });

        /* ── Attach to all Rate buttons ───────────────────────────────── */
        document.querySelectorAll('.btn-rate').forEach(function (btn) {
            btn.addEventListener('click', function () {
                if (!activityPassed) {
                    EventBoard.toast('Reviews are only available after the activity date.', 'error');
                    return;
                }
                openModal(btn);
            });
        });
    }());
    </script>
}

@functions {
    string GetStatusBadgeClass(string status) => status switch
    {
        "Accepted" => "badge-accepted",
        "Rejected"  => "badge-rejected",
        _           => "badge-pending"
    };
}
