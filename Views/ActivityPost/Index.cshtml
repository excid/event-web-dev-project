@model event_web_dev_project.Models.ActivityPost
@* Views/ActivityPost/Index.cshtml *@

<link rel="stylesheet" href="~/css/activity_post.css" />

@* Single hidden anti-forgery token — JS reads this for all AJAX requests *@
@Html.AntiForgeryToken()

@if (Model == null)
{
    <div style="text-align:center; padding:60px; color:#6b7280;">
        <p>No posts available yet.</p>
    </div>
}
else
{
    <div style="padding:16px 24px 0;">
        <a href="javascript:history.back()" class="back-link">
            <span data-icon="back"></span>
            Back
        </a>
    </div>

    <div class="event-detail-layout">

        <!-- ===== Left: Event Card ===== -->
        <div class="event-card">
            <div class="event-card-header">
                <span class="badge badge-sports">@Model.Category</span>
                <span class="badge @(Model.Status == "Open" ? "badge-open" : "badge-closed")">
                    @Model.Status
                </span>
            </div>

            <h1 class="event-title">@Model.Title</h1>

            <p class="event-posted-by">
                Posted by <a href="#">@Model.PostedBy</a>
                &bull; @Model.PostedAt.ToString("MMM d, yyyy")
            </p>

            <p class="event-section-label">Description</p>
            <p class="event-description">@Model.Description</p>

            <div class="event-meta-grid">

                <div class="event-meta-item">
                    <span class="meta-icon" data-icon="location"></span>
                    <div>
                        <div class="meta-label">Location</div>
                        <div class="meta-value">@Model.Location</div>
                    </div>
                </div>

                <div class="event-meta-item">
                    <span class="meta-icon" data-icon="members"></span>
                    <div>
                        <div class="meta-label">Members</div>
                        <div class="meta-value" id="member-count">
                            @Model.CurrentMembers / @Model.MaxMembers joined
                            @if (Model.SpotsLeft > 0)
                            {
                                <span class="meta-spots">(@Model.SpotsLeft spots left)</span>
                            }
                            else
                            {
                                <span class="meta-spots" style="color:#ef4444;">(Full)</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="event-meta-item">
                    <span class="meta-icon" data-icon="calendar"></span>
                    <div>
                        <div class="meta-label">Expires</div>
                        <div class="meta-value">@Model.ExpiresAt.ToString("MMM d, yyyy h:mm tt")</div>
                    </div>
                </div>

                <div class="event-meta-item">
                    <span class="meta-icon" data-icon="clock"></span>
                    <div>
                        <div class="meta-label">Application Mode</div>
                        <div class="meta-value">@Model.ApplicationMode</div>
                    </div>
                </div>

            </div>

            @if (Model.Status == "Open")
            {
                <button class="btn-close-post"
                        data-action="close-post"
                        data-post-id="@Model.Id">
                    <span data-icon="close"></span>
                    Close Post
                </button>
            }
        </div>

        <!-- ===== Right: Applications Panel ===== -->
        <div class="applications-panel">
            <h2 class="applications-title">Applications (@Model.Applications.Count)</h2>

            @if (!Model.Applications.Any())
            {
                <p style="color:#9ca3af; font-size:0.88rem;">No applications yet.</p>
            }
            else
            {
                <div class="application-list">
                    @foreach (var app in Model.Applications)
                    {
                        <div class="application-card">
                            <div class="application-card-header">
                                <span class="applicant-name">@app.ApplicantName</span>
                                <span class="badge @GetStatusBadgeClass(app.Status)">@app.Status</span>
                            </div>
                            <div class="application-time">
                                @app.AppliedAt.ToString("MMM d, h:mm tt")
                            </div>
                            <p class="application-message">@app.Message</p>

                            @if (app.Status == "Pending" && Model.Status == "Open")
                            {
                                <div class="application-actions">
                                    <button class="btn-accept"
                                            data-action="accept"
                                            data-application-id="@app.Id"
                                            data-post-id="@Model.Id">
                                        <span data-icon="check"></span>
                                        Accept
                                    </button>
                                    <button class="btn-reject"
                                            data-action="reject"
                                            data-application-id="@app.Id"
                                            data-post-id="@Model.Id">
                                        <span data-icon="x"></span>
                                        Reject
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

    </div>
}

<script src="~/js/icons.js"></script>
<script src="~/js/events.js"></script>

@functions {
    string GetStatusBadgeClass(string status) => status switch
    {
        "Accepted" => "badge-accepted",
        "Rejected"  => "badge-rejected",
        _           => "badge-pending"
    };
}
