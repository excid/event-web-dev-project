@model event_web_dev_project.Models.LoginViewModel
@* Views/Login/Login.cshtml *@

<link rel="stylesheet" href="~/css/LoginPage_c.css">

<div class="login-page-wrapper">
    <div class="container">
        <h1>Event Board</h1>
        <h2>Sign In to your account</h2>

        <div class="login-card">

            @* Show error message if login failed (wrong email/password) *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="login-error">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }

            @* asp-action / asp-controller tells the form WHERE to POST *@
            @* method="post" means clicking Sign In sends a POST request *@
            <form asp-action="Index" asp-controller="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="input-group">
                    <label asp-for="Email">Email address</label>
                    <input asp-for="Email"
                           type="email"
                           placeholder="Enter your email" />
                </div>

                <div class="input-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password"
                           type="password"
                           placeholder="Enter your password" />
                </div>

                <div class="form-helper">
                    <label>
                        <input asp-for="RememberMe" type="checkbox" /> Remember me
                    </label>
                    <a href="#">Forgot password?</a>
                </div>

                <button type="submit" class="signin-btn">Sign in</button>

                <p class="footer-signup">
                    Don't have an account? <a href="#">Signup</a>
                </p>
            </form>
        </div>

        <a href="#" class="guest-link">← Continue as guest (browse only)</a>
    </div>
</div>
