@model event_web_dev_project.Models.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="profile-container" id="profile-page-root">
    <!-- Top Profile Card -->
    <section class="profile-header-card" id="profile-card">
        <!-- VIEW MODE CONTAINER -->
        <div class="view-mode-container">
            <div class="profile-main-info">
                <div class="avatar-container">
                    <div class="avatar-placeholder">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img id="display-avatar" src="@Model.AvatarUrl" alt="Avatar" style="width:100%; height:100%; border-radius:50%; object-fit:cover;">
                        }
                        else
                        {
                            <svg id="default-avatar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        }
                    </div>
                </div>
                <div class="user-details">
                    <h1 id="display-name">@Model.DisplayName</h1>
                    <p class="email">@Model.Email</p>
                    <div class="rating-container">
                        <div class="stars">
                            @for (int i = 0; i < 5; i++)
                            {
                                <span class="star">@(i < Math.Floor(Model.Rating) ? "★" : "☆")</span>
                            }
                        </div>
                        <span class="rating-text">@Model.Rating (@Model.ReviewsCount reviews)</span>
                    </div>
                    <div class="quick-stats">
                        <span><i class="icon-stat"></i> @Model.OrganizedCount Organized</span>
                        <span><i class="icon-stat"></i> @Model.JoinedCount Joined</span>
                    </div>
                </div>
                <button class="edit-profile-btn" id="btn-edit-start" @(Model.IsOwner ? "" : "style=\"display:none;\"")>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                    </svg>
                    Edit Profile
                </button>
                @if (!Model.IsOwner)
                {
                    <a href="@Url.Action("Create", "Review", new { revieweeId = Model.UserId })"
                       class="edit-profile-btn"
                       aria-label="Write a review for @Model.DisplayName"
                       style="text-decoration:none;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="btn-icon">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                        </svg>
                        Write a Review
                    </a>
                }
            </div>

            <div class="profile-sections">
                <div class="section">
                    <h3>About</h3>
                    <p id="display-about">@(string.IsNullOrEmpty(Model.About) ? "No bio yet." : Model.About)</p>
                </div>
                <div class="section">
                    <h3>Tags</h3>
                    <div class="tag-list" id="display-tags">
                        @foreach (var tag in Model.TagList)
                        {
                            <span class="tag-chip">@tag</span>
                        }
                    </div>
                </div>
                <div class="section">
                    <h3>Interests</h3>
                    <div class="interest-list">
                        @foreach (var interest in Model.InterestList)
                        {
                            <span class="interest-chip @interest.ToLower()">@interest</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- EDIT MODE CONTAINER (Hidden by default, only shown to profile owner) -->
        <div class="edit-mode-container" style="display: none;">
            <form asp-action="UpdateProfile" method="post" id="form-edit-profile">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Tags" id="hidden-tags" />
                <input type="hidden" asp-for="Interests" id="hidden-interests" />
                <input type="hidden" asp-for="AvatarUrl" id="hidden-avatar-url" />

                <div class="profile-main-info">
                    <div class="avatar-container edit-avatar-wrapper">
                        <div class="avatar-placeholder clickable-avatar" id="avatar-upload-trigger">
                            <img id="edit-avatar-preview" src="@Model.AvatarUrl" alt="Preview" style="@(string.IsNullOrEmpty(Model.AvatarUrl) ? "display:none;" : "") width:100%; height:100%; border-radius:50%; object-fit:cover;">
                            <div class="upload-overlay">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="camera-icon">
                                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
                                    <circle cx="12" cy="13" r="4"></circle>
                                </svg>
                                <span>Update</span>
                            </div>
                            <input type="file" id="avatar-input" accept="image/*" style="display: none;">
                        </div>
                    </div>
                    <div class="user-details">
                        <div class="form-group">
                            <label asp-for="DisplayName"></label>
                            <input asp-for="DisplayName" id="input-name" class="form-control">
                            <span asp-validation-for="DisplayName" class="text-danger"></span>
                        </div>
                        <p class="email">@Model.Email <span class="badge-lock">(Read-only)</span></p>
                    </div>
                    <div class="edit-actions">
                        <button type="submit" class="btn-save" id="btn-edit-save-real">Save Changes</button>
                        <button type="button" class="btn-cancel-edit" id="btn-edit-cancel">Cancel</button>
                    </div>
                </div>

                <div class="profile-sections">
                    <div class="section full-width">
                        <h3>About</h3>
                        <textarea asp-for="About" id="input-about" class="form-control about-textarea" placeholder="Tell others about yourself..."></textarea>
                    </div>
                    <div class="section">
                        <h3>Tags</h3>
                        <div class="tag-manager">
                            <div class="tag-list edit-tag-list" id="edit-tag-list">
                                <!-- Tags with remove buttons will be injected here via JS -->
                            </div>
                            <div class="tag-input-group">
                                <input type="text" id="input-new-tag" placeholder="Add a tag..." maxlength="20">
                                <button type="button" id="btn-add-tag" class="btn-add">Add</button>
                            </div>
                        </div>
                    </div>
                    <div class="section">
                        <h3>Interests</h3>
                        <p class="helper-text">Selection of core interests is currently limited.</p>
                        <div class="interest-list" id="edit-interest-list">
                            @foreach (var interest in new[] { "Sports", "Dining", "Social" })
                            {
                                <span class="interest-chip @interest.ToLower() @(Model.InterestList.Contains(interest) ? "active" : "")" data-value="@interest">@interest</span>
                            }
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <div class="profile-footer">
            <label class="toggle-container">
                <input type="checkbox" checked>
                <span class="slider"></span>
                <span class="toggle-label"><i class="eye-icon"></i> Show my schedule to other users</span>
            </label>
        </div>
    </section>

    <!-- Bottom Content Grid -->
    <div class="profile-content-grid">
        <!-- Left Column: History -->
        <section class="content-box history-section">
            <div class="section-header">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="header-icon">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <h2>Recent Activity History</h2>
            </div>
            <div class="activity-list">
                @* This would normally be loaded from DB too, but keeping it static/mock for now as per plan focus *@
                @foreach (var post in Model.post_history)
                {
                    <div class="activity-card">
                        <div class="activity-card-header">
                            <h4>@post.Title</h4>
                            <span class="category-tag @post.Category.ToLower()">@post.Category</span>
                        </div>
                        <div class="activity-card-details">
                            <p><i class="location-icon"></i> @post.Location</p>
                            <p>Posted on: @post.PostedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                }
            </div>
        </section>

        <!-- Right Column -->
        <div class="right-column-stack">
            <!-- Upcoming Activities -->
            <section class="content-box upcoming-section">
                <div class="section-header">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="header-icon">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <h2>Upcoming Activities</h2>
                </div>
                <div class="activity-list">
                    @if (!Model.upcoming_activities.Any())
                    {
                        <p style="color:#9ca3af; font-size:0.88rem;">No upcoming activities.</p>
                    }
                    @foreach (var post in Model.upcoming_activities)
                    {
                        <div class="activity-card">
                            <div class="activity-card-header">
                                <h4>@post.Title</h4>
                                <span class="category-tag @post.Category.ToLower()">@post.Category</span>
                            </div>
                            <div class="activity-card-details">
                                <p><i class="location-icon"></i> @post.Location</p>
                                <p>Expires: @post.ExpiresAt.ToString("MMM d, h:mm tt")</p>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Reviews -->
            <section class="content-box reviews-section">
                <div class="section-header">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="header-icon">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                    <h2>Reviews</h2>
                </div>
                <div class="review-list">
                    @if (!Model.reviews.Any())
                    {
                        <p style="color:#9ca3af; font-size:0.88rem;">No reviews yet.</p>
                    }
                    @foreach (var review in Model.reviews)
                    {
                        <div class="review-item">
                            <div class="review-header">
                                <span class="reviewer-name">@review.ReviewerName</span>
                                <div class="review-stars">
                                    @(new string('★', review.Rating))@(new string('☆', 5 - review.Rating))
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <p class="review-text">@review.Comment</p>
                            }
                            <p class="review-date">@review.CreatedAt.ToString("MMM d, yyyy")</p>
                        </div>
                    }
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/profile.js" asp-append-version="true"></script>
}

