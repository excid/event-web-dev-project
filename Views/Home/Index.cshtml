@model List<event_web_dev_project.Models.ActivityPost>
@using System.Text.Json
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/decorate_main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animate.css" asp-append-version="true" />
    <title>Document</title>
</head>
<body>
    <section class="banner">
        <h1 class="title">Find New Friends</h1>
        <p class="subtitle">Connecting with Opportunities!</p>
        <div class="search-container">
            <input type="text" class="search-input" placeholder="">
            <button class="search-button">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                Search Event 
            </button>
        </div>

        <div class="stat-container">
            <div class="stat-item">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
                <div class="stat-text">
                    <span class="stat-number">@Model.Count</span>
                    <span class="stat-name">Event</span>
                </div>
            </div>
            <div class="stat-item">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                </div>
                <div class="stat-text">
                    <span class="stat-number">@Model.Sum(p => p.Applications.Count)</span>
                    <span class="stat-name">Candidates</span>
                </div>
            </div>
            <div class="stat-item">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="stat-text">
                    <span class="stat-number">@Model.Select(p => p.PostedBy).Distinct().Count()</span>
                    <span class="stat-name">Owner</span>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        
        <aside class="sidebar">
            <div class="filter-box">
                <div class="filter-group">
                    <label>Search by Event Title</label>
                    <div class="input-with-icon">
                        <i class="fa-solid fa-search icon"></i>
                        <input type="text" placeholder="Search...">
                    </div>
                </div>

                <div class="filter-group">
                    <label>Location</label>
                    <div class="input-with-icon">
                        <i class="fa-solid fa-location-dot icon"></i>
                        <select id="location-select">
                            <option value="">Any location</option>
                            @foreach (var location in ViewBag.Locations)
                            {
                                <option value="@location">@location</option>
                            }
                        </select>
                        <i class="fa-solid fa-chevron-down arrow-icon"></i>
                    </div>
                </div>

                <div class="filter-group">
                    <label>Sort by</label>
                    <div class="input-with-icon">
                        <select id="sort-select">
                            <option value="newest">Newest First</option>
                            <option value="expiring">Expiring Soon</option>
                            <option value="activity">Activity Date</option>
                            <option value="members">Most Members</option>
                        </select>
                        <i class="fa-solid fa-chevron-down arrow-icon"></i>
                    </div>
                </div>

                <div class="filter-group">
                    <label>Status</label>
                    <div class="checkbox-list">
                        <label class="checkbox-item">
                            <span><input type="checkbox" class="status-checkbox" value="Open"> Open</span>
                        </label>
                        <label class="checkbox-item">
                            <span><input type="checkbox" class="status-checkbox" value="Closed"> Closed</span>
                        </label>
                        <label class="checkbox-item">
                            <span><input type="checkbox" class="status-checkbox" value="Expired"> Expired</span>
                        </label>
                    </div>
                </div>

                <button class="btn-show-more" id="btn-show-more">Show More</button>

                <div id="extra-filters" style="display:none">

                    <div class="filter-group" style="margin-top:16px">
                        <label>Expires within</label>
                        <div class="input-with-icon">
                            <select id="date-select">
                                <option value="">Any time</option>
                                <option value="today">Today</option>
                                <option value="week">This week</option>
                                <option value="month">This month</option>
                            </select>
                            <i class="fa-solid fa-chevron-down arrow-icon"></i>
                        </div>
                    </div>

                    <div class="filter-group">
                        <label>Activity within</label>
                        <div class="input-with-icon">
                            <select id="activity-date-select">
                                <option value="">Any time</option>
                                <option value="today">Today</option>
                                <option value="week">This week</option>
                                <option value="month">This month</option>
                            </select>
                            <i class="fa-solid fa-chevron-down arrow-icon"></i>
                        </div>
                    </div>

                    <div class="filter-group">
                        <label>Category</label>
                        <div class="checkbox-list" id="category-list">
                            @foreach (var category in Model.Select(p => p.Category).Distinct())
                            {
                                var count = Model.Count(p => p.Category == category);
                                <label class="checkbox-item category-item">
                                    <span><input type="checkbox" value="@category"> @category</span>
                                    <span class="badge">@count</span>
                                </label>
                            }
                        </div>
                    </div>

                    <button class="btn-clear-filter" id="btn-clear-filter">
                        <i class="fa-solid fa-xmark"></i> Clear All Filters
                    </button>

                </div>
            </div>

            <div class="ad-banner">
                <h3>ADVERTISEMENT HERE</h3>
                <p>advertisement description!</p>
            </div>
        </aside>

        <main class="content">
            <div class="event-list" id="event-list-container"></div>

            <script>
                window.eventData = @Html.Raw(JsonSerializer.Serialize(Model.Select(p => new {
                    id             = p.Id,
                    title          = p.Title,
                    category       = p.Category,
                    description    = p.Description,
                    location       = p.Location,
                    postedBy       = p.PostedBy,
                    postedAt       = p.PostedAt.ToString("MMM d, yyyy"),
                    expiresAt      = p.ExpiresAt.ToString("MMM d, yyyy"),
                    activityDate   = p.ActivityDate.ToString("MMM d, yyyy"),
                    maxMembers     = p.MaxMembers,
                    currentMembers = p.CurrentMembers,
                    spotsLeft      = p.SpotsLeft,
                    status         = p.Status,
                    applicationsCount = p.Applications.Count
                })));
            </script>

            <div class="pagination" id="pagination"></div>

            <script src="~/js/card.js" asp-append-version="true"></script>
        </main>

    </div>
</body>
</html>