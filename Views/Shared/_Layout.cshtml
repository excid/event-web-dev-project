<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventBoard</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>

<body>
    <partial name="_NavBar" />

    <div class="page-content">
        <main role="main" class="pb-3 main-padding">
            @RenderBody()
        </main>
    </div>

    @* ── Notification System ── *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        @* Hidden anti-forgery token used by notifications.js for POST requests *@
        @Html.AntiForgeryToken()

        @* Floating bell button *@
        <button id="notif-fab" class="notif-fab" aria-label="Notifications" title="Notifications">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
            </svg>
            <span id="notif-badge" class="notif-badge" hidden>0</span>
        </button>

        @* Notification panel *@
        <div id="notif-panel" class="notif-panel" hidden>
            <div class="notif-panel-header">
                <h3>Notifications</h3>
                <button id="notif-mark-all" class="notif-mark-all-btn">Mark all as read</button>
            </div>
            <ul id="notif-list" class="notif-list" role="list"></ul>
        </div>

        <script src="~/js/notifications.js" asp-append-version="true"></script>
    }

    @RenderSection("Scripts", required: false)
</body>

</html>
