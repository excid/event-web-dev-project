# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# NuGet Symbol Packages
*.snupkg

# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Compiled JavaScript/TypeScript
*.js.map
*.ts.map
dist/
build/

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Temporary files
*.swp
*.swo
*~
.tmp

# Database files
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# IDE and Editor files
*.sublime-project
*.sublime-workspace

# Backup files
*.bak
*.backup
*.old

# Publish profiles
*.pubxml
*.publishproj

# Web publish folders
PublishProfiles/

# CSS preprocessors
.sass-cache/
*.css.map